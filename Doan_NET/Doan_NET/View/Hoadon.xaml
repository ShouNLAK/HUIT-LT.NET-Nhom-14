<UserControl x:Class="Doan_NET.View.Hoadon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Doan_NET.View"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1300"
             Background="#F5F5F5">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="0.8*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="0,0,10,0" Padding="15">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="LỊCH SỬ GIAO DỊCH CHI TIẾT" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <DataGrid x:Name="dgSelectedItems" ItemsSource="{Binding CurrentCart}" 
          AutoGenerateColumns="False" Background="Transparent" 
          CanUserAddRows="False" GridLinesVisibility="Horizontal" BorderThickness="0.5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Width="40" Binding="{Binding STT}"/>

                        <DataGridTextColumn Header="Ngày lập" Width="100" Binding="{Binding NgayLap, StringFormat=dd/MM/yyyy}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="NV Quản lý" Width="130" Binding="{Binding TenNhanVien}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontStyle" Value="Italic"/>
                                    <Setter Property="Foreground" Value="#2C3E50"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Tên khách" Width="130" Binding="{Binding TenKhachHang}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="SĐT" Width="100" Binding="{Binding SDTKhach}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="Gray"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Tên sản phẩm / Dịch vụ" Width="*" Binding="{Binding Ten}"/>

                        <DataGridTemplateColumn Header="SL" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding SL}" TextAlignment="Center" BorderThickness="0.5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Đơn giá" Width="100" Binding="{Binding Gia, StringFormat={}{0:N0}}"/>

                        <DataGridTextColumn Header="Thành tiền" Width="110" Binding="{Binding Tong, StringFormat={}{0:N0}}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15">
            <StackPanel>
                <TextBlock Text="THÔNG TIN THANH TOÁN" FontSize="16" FontWeight="Bold" Foreground="#E67E22" Margin="0,0,0,15"/>

                <UniformGrid Columns="2" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Nhân viên:" FontSize="11" Foreground="Gray"/>
                        <TextBlock Text="Lê Văn Admin" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right">
                        <TextBlock Text="Ngày lập:" FontSize="11" Foreground="Gray"/>
                        <TextBlock Text="02/04/2024" FontWeight="SemiBold"/>
                    </StackPanel>
                </UniformGrid>

                <TextBlock Text="Số điện thoại khách:" FontSize="11" Foreground="Gray"/>
                <Grid Margin="0,5,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtQuickSearchKH" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    <Button Grid.Column="1" Content="Check" Width="50" Margin="5,0,0,0" Background="#34495E" Foreground="White" BorderThickness="0"/>
                </Grid>

                <Border Background="#F9F9F9" Padding="10" CornerRadius="5" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedCustomer.HoTen, FallbackValue='Nguyễn Văn A'}" FontWeight="Bold"/>
                        <TextBlock Text="Địa chỉ: Quận 1, TP.HCM" FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Sản phẩm đang chọn:" FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>
                <ListBox ItemsSource="{Binding CurrentCart}" Height="120" d:ItemsSource="{d:SampleData ItemCount=3}"
                         BorderBrush="#EEEEEE" BorderThickness="1" Background="#FAFAFA">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="300" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Ten}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1" Text="{Binding SL, StringFormat='x{0}'}" Margin="10,0" Foreground="#2980B9"/>
                                <TextBlock Grid.Column="2" Text="{Binding Tong, StringFormat={}{0:N0}}" Foreground="#E67E22" FontWeight="Bold"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="Hình thức thanh toán:" FontSize="11" Foreground="Gray" Margin="0,15,0,5"/>
                <ComboBox SelectedIndex="0" Height="30" Margin="0,0,0,15">
                    <ComboBoxItem Content="Tiền mặt"/>
                    <ComboBoxItem Content="Chuyển khoản"/>
                    <ComboBoxItem Content="Trả góp"/>
                </ComboBox>

                <Separator Margin="0,0,0,15"/>

                <Grid Margin="0,0,0,8">
                    <TextBlock Text="Tổng tiền hàng:"/>
                    <TextBlock Text="{Binding TotalOrderPrice, StringFormat={}{0:N0}}" HorizontalAlignment="Right" FontWeight="Bold"/>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="Giảm giá (%):"/>
                    <TextBox Width="50" HorizontalAlignment="Right" Text="0" TextAlignment="Right"/>
                </Grid>
                <Grid Margin="0,10,0,20">
                    <TextBlock Text="THÀNH TIỀN:" FontWeight="Bold" FontSize="16" Foreground="#E74C3C" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding FinalPrice, StringFormat={}{0:N0}}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="22" Foreground="#E74C3C"/>
                </Grid>

                <Button Content="XÁC NHẬN THANH TOÁN" Height="55" Background="#27AE60" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                    </Button.Effect>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
<UserControl x:Class="Doan_NET.View.Khachhang"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Doan_NET.View"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#F5F5F5">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.8*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="0,0,10,0" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="DANH SÁCH KHÁCH HÀNG" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBox x:Name="txtSearch" Width="200" Height="30" VerticalContentAlignment="Center" Margin="0,0,5,0" Tag="Tìm tên, SĐT..."/>
                    <Button Content="Tìm kiếm" Width="80" Height="30" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Separator Width="30" Background="Transparent"/>
                    <Button Content="+ Thêm mới" Width="100" Height="30" Background="#27AE60" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"/>
                    <Button Content="🗑 Xóa" Width="80" Height="30" Background="#E74C3C" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
                <DataGrid x:Name="dgCustomers" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="Horizontal" Background="White" BorderThickness="0" RowHeight="35" FontSize="13">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã KH" Binding="{Binding MaKH}" Width="80"/>
                        <DataGridTextColumn Header="Họ và Tên" Binding="{Binding HoTen}" Width="*"/>
                        <DataGridTextColumn Header="Số điện thoại" Binding="{Binding SDT}" Width="110"/>
                        <DataGridTextColumn Header="Loại KH" Binding="{Binding LoaiKH}" Width="100"/>
                        <DataGridTemplateColumn Header="Chi tiêu" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TongChiTieu, StringFormat={}{0:N0} VNĐ}" Foreground="#E74C3C" FontWeight="Bold" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="THÔNG TIN HỒ SƠ" FontSize="16" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,15"/>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Mã khách hàng (Tự động):" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding SelectedCustomer.MaKH}" IsReadOnly="True" Background="#F0F0F0" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Họ và Tên:" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding SelectedCustomer.HoTen, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Số điện thoại:" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding SelectedCustomer.SDT}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Loại khách hàng:" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                            <ComboBox SelectedValue="{Binding SelectedCustomer.LoaiKH}" Height="30">
                                <ComboBoxItem Content="Cá nhân"/>
                                <ComboBoxItem Content="Doanh nghiệp"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Số CCCD / Mã số thuế:" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding SelectedCustomer.DinhDanh}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Địa chỉ:" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding SelectedCustomer.DiaChi}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Email:" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding SelectedCustomer.Email}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <Button Content="LƯU / CẬP NHẬT HỒ SƠ" 
                            Background="#27AE60" Foreground="White" 
                            Height="35" FontWeight="Bold" BorderThickness="0" Margin="0,10,0,20"
                            ToolTip="Nhấn để Thêm mới hoặc Cập nhật thông tin hiện tại"/>

                    <Separator Margin="0,0,0,15" Background="#EEE"/>

                    <TextBlock Text="LỊCH SỬ GIAO DỊCH (XE &amp; DỊCH VỤ)" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    <DataGrid ItemsSource="{Binding SelectedCustomer.Transactions}" Height="150" IsReadOnly="True" AutoGenerateColumns="False" Background="#FAFAFA">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ngày" Binding="{Binding NgayLap, StringFormat=dd/MM/yyyy}" Width="85"/>
                            <DataGridTextColumn Header="Loại" Binding="{Binding LoaiGD}" Width="70"/>
                            <DataGridTextColumn Header="Nội dung" Binding="{Binding NoiDung}" Width="*"/>
                            <DataGridTextColumn Header="Tổng Tiền" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
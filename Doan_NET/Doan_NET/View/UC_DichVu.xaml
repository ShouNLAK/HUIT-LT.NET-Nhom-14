<UserControl x:Class="Doan_NET.View.UC_DichVu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Doan_NET.View"
             xmlns:vm="clr-namespace:Doan_NET.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#F5F5F5">
    <UserControl.DataContext>
        <vm:DichVu_VM/>
    </UserControl.DataContext>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="0,0,10,0" Padding="15">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="QUẢN LÝ DỊCH VỤ &amp; PHỤ TÙNG" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="txtSearchDichVu" Width="250" Height="35" VerticalContentAlignment="Center" 
                             Tag="Tìm tên phụ tùng..." Padding="10,0"/>
                        <Button Content="Tìm kiếm" Width="80" Margin="5,0" Background="#34495E" Foreground="White" BorderThickness="0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="➕ THÊM MỚI" Width="100" Height="35" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5,0" Command="{Binding LenhMoThemDichVu}"/>
                        <Button Content="📝 SỬA" Width="80" Height="35" Background="#F1C40F" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5,0" Command="{Binding LenhMoSuaDichVu}"/>
                        <Button Content="🗑️ XÓA" Width="80" Height="35" Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5,0"/>
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="dgDichVu" AutoGenerateColumns="False" Background="Transparent" IsReadOnly="True" GridLinesVisibility="Horizontal" BorderThickness="0.5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã PT" Width="80" Binding="{Binding MaPhuTung}"/>
                        <DataGridTextColumn Header="Tên Phụ tùng / Dịch vụ" Width="*" Binding="{Binding Ten}"/>
                        <DataGridTextColumn Header="Tồn kho" Width="80" Binding="{Binding TonKho}"/>
                        <DataGridTextColumn Header="Đơn giá" Width="120" Binding="{Binding Gia, StringFormat={}{0:N0}}"/>
                        <DataGridTemplateColumn Header="Thêm giỏ hàng" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="CHỌN BÁN" Background="#3498DB" Foreground="White" FontWeight="Bold" Padding="5,2" BorderThickness="0" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="ĐƠN HÀNG TẠM TÍNH" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="#E67E22"/>

                <Button DockPanel.Dock="Bottom" Content="TỚI MÀN HÌNH THANH TOÁN" Height="55" Background="#E67E22" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Margin="0,15,0,0" Command="{Binding LenhThanhToan}"/>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <Separator Background="#EEEEEE" Margin="0,5"/>
                    <Grid Margin="0,5">
                        <TextBlock Text="Tổng tiền tạm tính:" FontSize="14" Foreground="Gray"/>
                        <TextBlock Text="1.250.000 VNĐ" HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="#E74C3C"/>
                    </Grid>
                </StackPanel>

                <ListBox x:Name="lstSelectedTemp" BorderThickness="1" BorderBrush="#F0F0F0" Background="#FAFAFA">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="5,10">
                                <Grid Width="310">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Ten}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Gia, StringFormat={}{0:N0}}" FontSize="11" Foreground="Gray"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                        <Button Content="-" Width="22" Height="22" Background="#F5F5F5" BorderBrush="#DDD"/>
                                        <TextBlock Text="{Binding SL}" Margin="8,0" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <Button Content="+" Width="22" Height="22" Background="#F5F5F5" BorderBrush="#DDD"/>
                                    </StackPanel>

                                    <Button Grid.Column="2" Content="❌" Foreground="#E74C3C" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" FontSize="14"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

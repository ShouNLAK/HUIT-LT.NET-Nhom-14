<UserControl x:Class="Doan_NET.View.Thongke"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Doan_NET.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0.8*"/>
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,20">
            <Border Background="White" CornerRadius="10" Margin="0,0,10,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="TỔNG DOANH THU" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="1,250,000,000" FontSize="22" FontWeight="Bold" Foreground="#27AE60"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Margin="5,0,5,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="HÓA ĐƠN MỚI" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="145" FontSize="22" FontWeight="Bold" Foreground="#2980B9"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Margin="10,0,0,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="KHÁCH HÀNG" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="+28" FontSize="22" FontWeight="Bold" Foreground="#8E44AD"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Margin="0,0,0,20" Padding="20">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="DOANH THU 6 THÁNG GẦN NHẤT" FontWeight="Bold" Margin="0,0,0,20"/>

                <ItemsControl ItemsSource="{Binding RevenueData}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="6" VerticalAlignment="Bottom"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Bottom" Margin="10,0">
                                <Border Background="#3498DB" Width="40" 
                                        Height="{Binding Value}" 
                                        CornerRadius="5,5,0,0"
                                        ToolTip="{Binding ValueDisplay}"/>
                                <TextBlock Text="{Binding MonthName}" HorizontalAlignment="Center" Margin="0,5,0,0" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1"/>
                </Border.Effect>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="🛠️" FontSize="18" Margin="0,0,10,0"/>
                        <TextBlock Text="DỊCH VỤ BÁN CHẠY" FontSize="15" FontWeight="Bold" Foreground="#2C3E50"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding TopSellingServices}" AutoGenerateColumns="False" 
                      CanUserAddRows="False" Background="Transparent" BorderThickness="0"
                      RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tên dịch vụ" Binding="{Binding TenDV_SP}" Width="*"/>
                            <DataGridTextColumn Header="Số lượng" Binding="{Binding SOLUONG}" Width="80"/>
                            <DataGridTextColumn Header="Doanh thu" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#27AE60"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15" Margin="10,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1"/>
                </Border.Effect>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="🏍️" FontSize="18" Margin="0,0,10,0"/>
                        <TextBlock Text="XE BÁN CHẠY NHẤT" FontSize="15" FontWeight="Bold" Foreground="#2C3E50"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding TopSellingVehicles}" AutoGenerateColumns="False" 
                      CanUserAddRows="False" Background="Transparent" BorderThickness="0"
                      RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mẫu xe" Binding="{Binding TenDV_SP}" Width="*"/>
                            <DataGridTextColumn Header="Đã bán" Binding="{Binding SOLUONG}" Width="80"/>
                            <DataGridTextColumn Header="Doanh số" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#E67E22"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

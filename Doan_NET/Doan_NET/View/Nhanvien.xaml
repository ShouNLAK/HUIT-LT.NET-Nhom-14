<UserControl x:Class="Doan_NET.View.Nhanvien"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Doan_NET.View"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1100"
             Background="#F5F5F5">
    <Grid Margin="15">
        <Border Background="White" CornerRadius="10" Padding="20">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                    <TextBlock Text="QUẢN LÝ DANH SÁCH NHÂN VIÊN" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="txtSearchNV" Width="300" Height="35" VerticalContentAlignment="Center" 
                                     Tag="Nhập tên hoặc mã nhân viên..." Padding="10,0" Margin="0,0,10,0"/>
                            <Button Content="🔍 Tìm kiếm" Width="100" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="➕ THÊM NHÂN VIÊN" Width="140" Height="35" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5,0" Cursor="Hand"/>
                            <Button Content="📝 SỬA" Width="80" Height="35" Background="#F1C40F" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5,0" Cursor="Hand"/>
                            <Button Content="🗑️ XÓA" Width="80" Height="35" Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5,0" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Border DockPanel.Dock="Top" Background="#F9FAFB" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="THÔNG TIN CHI TIẾT NHÂN VIÊN CHỌN" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,10"/>

                        <UniformGrid Grid.Row="1" Columns="6">
                            <StackPanel Margin="5,0">
                                <TextBlock Text="Mã NV" FontSize="11" Foreground="Gray"/>
                                <TextBox Text="{Binding ElementName=dgNhanVien, Path=SelectedItem.MaNV}" IsReadOnly="True" FontWeight="Bold" BorderThickness="0,0,0,1" Background="Transparent"/>
                            </StackPanel>

                            <StackPanel Margin="5,0">
                                <TextBlock Text="Họ và Tên" FontSize="11" Foreground="Gray"/>
                                <TextBox Text="{Binding ElementName=dgNhanVien, Path=SelectedItem.HoTen}" IsReadOnly="True" FontWeight="Bold" BorderThickness="0,0,0,1" Background="Transparent"/>
                            </StackPanel>

                            <StackPanel Margin="5,0">
                                <TextBlock Text="Số điện thoại" FontSize="11" Foreground="Gray"/>
                                <TextBox Text="{Binding ElementName=dgNhanVien, Path=SelectedItem.SDT}" IsReadOnly="True" FontWeight="Bold" BorderThickness="0,0,0,1" Background="Transparent"/>
                            </StackPanel>

                            <StackPanel Margin="5,0">
                                <TextBlock Text="Chức vụ" FontSize="11" Foreground="Gray"/>
                                <TextBox Text="{Binding ElementName=dgNhanVien, Path=SelectedItem.ChucVu}" IsReadOnly="True" FontWeight="Bold" BorderThickness="0,0,0,1" Background="Transparent" Foreground="#2980B9"/>
                            </StackPanel>

                            <StackPanel Margin="5,0">
                                <TextBlock Text="Ngày vào làm" FontSize="11" Foreground="Gray"/>
                                <TextBox Text="{Binding ElementName=dgNhanVien, Path=SelectedItem.NgayVaoLam, StringFormat=dd/MM/yyyy}" IsReadOnly="True" FontWeight="Bold" BorderThickness="0,0,0,1" Background="Transparent"/>
                            </StackPanel>

                            <StackPanel Margin="5,0">
                                <TextBlock Text="Trạng thái" FontSize="11" Foreground="Gray"/>
                                <TextBox Text="Đang làm việc" IsReadOnly="True" FontWeight="Bold" BorderThickness="0,0,0,1" Background="Transparent" Foreground="#1E8449"/>
                            </StackPanel>
                        </UniformGrid>
                    </Grid>
                </Border>

                <Border BorderBrush="#EEEEEE" BorderThickness="1" CornerRadius="5">
                    <DataGrid x:Name="dgNhanVien" AutoGenerateColumns="False" CanUserAddRows="False" 
                              Background="Transparent" GridLinesVisibility="Horizontal" 
                              BorderThickness="0" RowHeight="40" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã NV" Width="80" Binding="{Binding MaNV}"/>
                            <DataGridTextColumn Header="Họ và Tên" Width="*" Binding="{Binding HoTen}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="5,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Số điện thoại" Width="120" Binding="{Binding SDT}"/>

                            <DataGridTextColumn Header="Chức vụ" Width="120" Binding="{Binding ChucVu}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#2980B9"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Ngày vào làm" Width="120" Binding="{Binding NgayVaoLam, StringFormat=dd/MM/yyyy}"/>

                            <DataGridTemplateColumn Header="Trạng thái" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#D5F5E3" CornerRadius="10" HorizontalAlignment="Center" Padding="8,2">
                                            <TextBlock Text="Đang làm việc" Foreground="#1E8449" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>